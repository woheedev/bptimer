{
	"name": "web",
	"version": "0.0.1",
	"author": "Wohee",
	"description": "Sveltekit frontend for the BPSR Timer Panel monorepo",
	"license": "AGPL-3.0-or-later",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run --bun vite build",
		"check": "bun run --bun svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun run --bun svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "wrangler deploy",
		"dev": "bun run --bun svelte-kit sync && bun run --bun vite dev",
		"lint": "eslint .",
		"preview": "vite preview",
		"shadcn-add": "bunx shadcn-svelte@latest add",
		"test": "playwright test"
	},
	"dependencies": {
		"mode-watcher": "^1.1.0",
		"pako": "^2.1.0",
		"pocketbase": "^0.27.0",
		"simple-icons": "^16.21.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.17.0",
		"@playwright/test": "^1.60.0",
		"@repo/eslint-config": "workspace:*",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.1",
		"@types/pako": "^2.0.4",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.10",
		"svelte-check": "^4.4.8",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tslib": "^2.8.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^8.0.14"
	}
}
